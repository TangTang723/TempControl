<UserControl x:Class="PrismTemperatureMonitor.Views.TemperatureMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1440">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="MonitorLaserItemStyle" TargetType="Border">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#DCEBFA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>
        <Style x:Key="MonitorLaserLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,5,0" />
        </Style>
        <Style x:Key="MonitorLaserValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ShellBackgroundBrush}" Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelCardStyle}" Padding="18,14" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="温度曲线监控" FontSize="26" FontWeight="SemiBold" />
                    <TextBlock Text="单温区实时温度趋势、上下限与结果判定"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="13"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#22C55E" Margin="0,0,8,0" />
                    <StackPanel>
                        <TextBlock Text="设备连接" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                        <TextBlock Text="{Binding ConnectionState}" FontSize="16" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="{Binding CollectionStateBrush}" Margin="0,0,8,0" />
                    <StackPanel>
                        <TextBlock Text="采集状态" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                        <TextBlock Text="{Binding CollectionState}" FontSize="16" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="{Binding AlarmStateBrush}" Margin="0,0,8,0" />
                    <StackPanel>
                        <TextBlock Text="当前状态" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                        <TextBlock Text="{Binding AlarmState}" FontSize="16" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,18,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="实时趋势" FontSize="19" FontWeight="SemiBold" />
                            <TextBlock Text="横坐标为采样时间，鼠标滚轮可横向放大或缩小温度曲线"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Rectangle Width="22" Height="3" Fill="#0EA5E9" VerticalAlignment="Center" />
                            <TextBlock Text="温区" Foreground="{StaticResource SecondaryTextBrush}" Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#FBFDFF"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8">
                        <lvc:CartesianChart Series="{Binding Series}"
                                            XAxes="{Binding XAxes}"
                                            YAxes="{Binding YAxes}"
                                            ZoomMode="X"
                                            LegendPosition="Hidden"
                                            TooltipPosition="Top"
                                            Background="#FBFDFF"
                                            DrawMarginFrame="{x:Null}" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,0,10" Padding="15,11">
                    <StackPanel>
                        <TextBlock Text="当前温度" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                        <TextBlock Text="{Binding CurrentTemperature, StringFormat={}{0:F1} °C}"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="当前配方"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="12"
                                   Margin="0,8,0,4" />
                        <ComboBox ItemsSource="{Binding TemperatureRecipes}"
                                  SelectedItem="{Binding SelectedTemperatureRecipe, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  Height="32"
                                  VerticalContentAlignment="Center" />
                    </StackPanel>
                </Border>

                <UniformGrid Grid.Row="1" Columns="2" Rows="2">
                    <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,8,8" Padding="12,9">
                        <StackPanel>
                            <TextBlock Text="目标温度" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                            <TextBlock Text="{Binding TargetTemperature, StringFormat={}{0:F0} °C}" FontSize="19" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,0,8" Padding="12,9">
                        <StackPanel>
                            <TextBlock Text="温度上限" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                            <TextBlock Text="{Binding TemperatureUpperLimit, StringFormat={}{0:F1} °C}" FontSize="19" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,8,10" Padding="12,9">
                        <StackPanel>
                            <TextBlock Text="温度下限" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                            <TextBlock Text="{Binding TemperatureLowerLimit, StringFormat={}{0:F1} °C}" FontSize="19" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,0,10" Padding="12,9">
                        <StackPanel>
                            <TextBlock Text="温度结果" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                            <TextBlock Text="{Binding TemperatureResult}"
                                       Foreground="{Binding TemperatureResultBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="2" Style="{StaticResource PanelCardStyle}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="178" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="激光器参数" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding LaserSelectionMessage}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="11"
                                            Margin="0,2,8,0"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Height="32"
                                      ItemsSource="{Binding ConnectedLaserDevices}"
                                      SelectedItem="{Binding SelectedLaserDevice, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      VerticalContentAlignment="Center" />
                        </Grid>

                        <Border Grid.Row="1" Height="1" Background="#E2E8F0" Margin="0,8" />

                        <Grid Grid.Row="2"
                              Visibility="{Binding IsHwqLaserSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource MonitorLaserItemStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="激光功率(W):" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.RealtimePower, StringFormat={}{0:F1}}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource MonitorLaserItemStyle}" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="波形号:" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.WaveNumber}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource MonitorLaserItemStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="波形模式:" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.WaveMode}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource MonitorLaserItemStyle}" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="触发方式:" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.TriggerMode}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource MonitorLaserItemStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="单点能量(J):" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.SinglePointEnergy, StringFormat={}{0:F2}}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource MonitorLaserItemStyle}" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="出光点数:" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.OutputPointCount}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource MonitorLaserItemStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="平均功率(W):" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.AveragePower, StringFormat={}{0:F2}}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource MonitorLaserItemStyle}" Margin="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="模拟量(V):" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.AnalogVoltage, StringFormat={}{0:F2}}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2"
                              Visibility="{Binding IsHwdLaserSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource MonitorLaserItemStyle}" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="实时功率(W):" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.RealtimePower, StringFormat={}{0:F2}}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource MonitorLaserItemStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="波形号:" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.WaveNumber}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource MonitorLaserItemStyle}" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="出光模式:" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.WaveMode}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource MonitorLaserItemStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="触发模式:" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.TriggerMode}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource MonitorLaserItemStyle}" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="最大功率(W):" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.MaximumPower, StringFormat={}{0:F1}}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource MonitorLaserItemStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="脉冲间隔(ms):" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.PulseInterval, StringFormat={}{0:F3}}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource MonitorLaserItemStyle}" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="平均功率(W):" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.AveragePower, StringFormat={}{0:F2}}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource MonitorLaserItemStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="单点能量(J):" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.SinglePointEnergy, StringFormat={}{0:F2}}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource MonitorLaserItemStyle}" Margin="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="出光点数:" Style="{StaticResource MonitorLaserLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentLaserSnapshot.OutputPointCount}" Style="{StaticResource MonitorLaserValueStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelCardStyle}" Margin="0,18,0,0" Padding="16">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="开始采集"
                            Command="{Binding StartCollectingCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Content="停止采集"
                            Command="{Binding StopCollectingCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="清空曲线"
                            Command="{Binding ClearChartCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
                <TextBlock HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="图表渲染点数已限制，长时间采集时保持刷新性能稳定。" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
