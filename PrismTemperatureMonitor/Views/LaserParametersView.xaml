<UserControl x:Class="PrismTemperatureMonitor.Views.LaserParametersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1440">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="LaserInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="LaserLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="LaserComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="LaserControlButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="LaserSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ParameterInfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,6" />
        </Style>

        <Style x:Key="ParameterInfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="HeaderParameterItemStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,0,10,12" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="HeaderParameterLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="HeaderParameterValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="HeaderStatusCardStyle" TargetType="Border">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="16,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="HeaderStatusValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ParameterSummaryItemStyle" TargetType="Border">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#DCEBFA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>

        <Style x:Key="ParameterSummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="ParameterSummaryValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ShellBackgroundBrush}" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCardStyle}" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,18,0">
                    <TextBlock Text="激光器参数" FontSize="23" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding OperationMessage}"
                               Margin="0,5,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Style="{StaticResource HeaderStatusCardStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="{Binding DisplayOutputStatusBrush}"
                                     Margin="0,0,8,0" />
                            <TextBlock Style="{StaticResource HeaderStatusValueStyle}">
                                <Run Text="出光状态：" />
                                <Run Text="{Binding DisplayOutputStatus, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HeaderStatusCardStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="{Binding DisplayAlarmStatusBrush}"
                                     Margin="0,0,8,0" />
                            <TextBlock Style="{StaticResource HeaderStatusValueStyle}">
                                <Run Text="报警状态：" />
                                <Run Text="{Binding DisplayAlarmStatus, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="激光器列表" FontSize="19" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Devices.Count, StringFormat=共 {0} 台}"
                                   DockPanel.Dock="Right"
                                   HorizontalAlignment="Right"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Devices}"
                              SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              IsReadOnly="True"
                              BorderBrush="{StaticResource PanelBorderBrush}"
                              BorderThickness="1"
                              RowHeight="34"
                              FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="型号" Binding="{Binding Model}" Width="58" />
                            <DataGridTextColumn Header="串口" Binding="{Binding PortName}" Width="76" />
                            <DataGridTextColumn Header="波特率" Binding="{Binding BaudRate}" Width="82" />
                            <DataGridTextColumn Header="状态" Binding="{Binding ConnectionState}" Width="68" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            Background="#F8FAFC"
                            Padding="12"
                            Margin="0,12,0,0"
                            CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="54" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="62" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名称" Style="{StaticResource LaserLabelStyle}" />
                            <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                                     Text="{Binding NewDeviceName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource LaserInputStyle}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="串口" Style="{StaticResource LaserLabelStyle}" Margin="0,8,8,0" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding NewPortName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource LaserInputStyle}"
                                     Margin="0,8,12,0" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="波特率" Style="{StaticResource LaserLabelStyle}" Margin="0,8,8,0" />
                            <TextBox Grid.Row="1" Grid.Column="3"
                                     Text="{Binding NewBaudRate, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource LaserInputStyle}"
                                     Margin="0,8,0,0" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="型号" Style="{StaticResource LaserLabelStyle}" Margin="0,8,8,0" />
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      ItemsSource="{Binding DeviceModels}"
                                      SelectedItem="{Binding NewDeviceModel}"
                                      Style="{StaticResource LaserComboStyle}"
                                      Margin="0,8,12,0" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="2"
                                       Text="功率精度"
                                       Style="{StaticResource LaserLabelStyle}"
                                       Margin="0,8,8,0"
                                       Visibility="{Binding IsNewDeviceHwd, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ComboBox Grid.Row="2"
                                      Grid.Column="3"
                                      ItemsSource="{Binding HwdPowerScales}"
                                      SelectedItem="{Binding NewHwdPowerScale}"
                                      Style="{StaticResource LaserComboStyle}"
                                      Margin="0,8,0,0"
                                      Visibility="{Binding IsNewDeviceHwd, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="新增"
                                        Command="{Binding AddDeviceCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Content="保存"
                                        Command="{Binding SaveSelectedDeviceCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="删除"
                                        Command="{Binding RemoveSelectedDeviceCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelCardStyle}"
                        Padding="12"
                        Margin="0,0,0,10"
                        Visibility="{Binding IsHwqSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="8" Margin="0,0,0,10">
                            <TextBlock Text="HWQ 波形基础参数" FontSize="18" FontWeight="SemiBold" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="保存波形"
                                        Command="{Binding SaveWaveCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Width="112"
                                        Height="36" />
                                <Button Content="切换波形"
                                        Command="{Binding SwitchWaveCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Width="112"
                                        Height="36" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="波形号" Style="{StaticResource LaserLabelStyle}" />
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding WaveNumbers}"
                                  SelectedItem="{Binding CurrentWaveSettings.WaveNumber}"
                                  Style="{StaticResource LaserComboStyle}"
                                  Width="100"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,16,8" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="波形模式" Style="{StaticResource LaserLabelStyle}" />
                        <ComboBox Grid.Row="1" Grid.Column="3"
                                  ItemsSource="{Binding WaveModes}"
                                  SelectedIndex="{Binding CurrentWaveSettings.WaveModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource LaserComboStyle}"
                                  Width="100"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,16,8" />
                        <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding WaveFrequencyLabel}" Style="{StaticResource LaserLabelStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="5"
                                 Text="{Binding CurrentWaveSettings.OutputFrequency}"
                                 Style="{StaticResource LaserInputStyle}"
                                 Width="100"
                                 HorizontalAlignment="Left"
                                 Margin="0,0,16,8" />
                        <TextBlock Grid.Row="1" Grid.Column="6" Text="{Binding MaxOutputFrequencyLabel}" Style="{StaticResource LaserLabelStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="7"
                                 Text="{Binding CurrentWaveSettings.MaxOutputFrequency}"
                                 Style="{StaticResource LaserInputStyle}"
                                 Width="100"
                                 HorizontalAlignment="Left"
                                 Margin="0,0,0,8" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="峰值功率" Style="{StaticResource LaserLabelStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding CurrentWaveSettings.MaximumPeakPower}"
                                 Style="{StaticResource LaserInputStyle}"
                                 Width="100"
                                 HorizontalAlignment="Left"
                                 Margin="0,0,16,0" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="平均功率" Style="{StaticResource LaserLabelStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="3"
                                 Text="{Binding CurrentWaveSettings.MaximumAveragePower}"
                                 Style="{StaticResource LaserInputStyle}"
                                 Width="100"
                                 HorizontalAlignment="Left"
                                 Margin="0,0,16,0" />
                        <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding PresetEnergyLabel}" Style="{StaticResource LaserLabelStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="5"
                                 Text="{Binding CurrentWaveSettings.PresetLaserEnergy}"
                                 Style="{StaticResource LaserInputStyle}"
                                 Width="100"
                                 HorizontalAlignment="Left"
                                 Margin="0,0,16,0" />
                        <TextBlock Grid.Row="2" Grid.Column="6" Text="{Binding AlarmRangeLabel}" Style="{StaticResource LaserLabelStyle}" />
                        <StackPanel Grid.Row="2" Grid.Column="7" Orientation="Horizontal">
                            <TextBox Text="{Binding CurrentWaveSettings.EnergyAlarmUpper}"
                                     Style="{StaticResource LaserInputStyle}"
                                     Width="78"
                                     Margin="0,0,8,0" />
                            <TextBox Text="{Binding CurrentWaveSettings.EnergyAlarmLower}"
                                     Style="{StaticResource LaserInputStyle}"
                                     Width="78" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelCardStyle}"
                        Padding="12"
                        Margin="0,0,0,10"
                        Visibility="{Binding IsHwdSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="82" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="8" Margin="0,0,0,10">
                            <TextBlock Text="HWD 波形基础参数" FontSize="18" FontWeight="SemiBold" />
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Content="保存波形"
                                        Command="{Binding SaveWaveCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Width="112"
                                        Height="36" />
                                <Button Content="切换波形"
                                        Command="{Binding SwitchWaveCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Width="112"
                                        Height="36" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="波形号" Style="{StaticResource LaserLabelStyle}" />
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding WaveNumbers}"
                                  SelectedItem="{Binding CurrentHwdWaveSettings.WaveNumber}"
                                  Style="{StaticResource LaserComboStyle}"
                                  Margin="0,0,16,8" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="出光模式" Style="{StaticResource LaserLabelStyle}" />
                        <ComboBox Grid.Row="1" Grid.Column="3"
                                  ItemsSource="{Binding HwdEmitModes}"
                                  SelectedItem="{Binding CurrentHwdWaveSettings.EmitMode}"
                                  Style="{StaticResource LaserComboStyle}"
                                  Margin="0,0,16,8" />
                        <TextBlock Grid.Row="1" Grid.Column="4" Text="触发模式" Style="{StaticResource LaserLabelStyle}" />
                        <ComboBox Grid.Row="1" Grid.Column="5"
                                  ItemsSource="{Binding HwdTriggerModes}"
                                  SelectedItem="{Binding CurrentHwdWaveSettings.TriggerMode}"
                                  IsEnabled="{Binding CanEditHwdTrigger}"
                                  Style="{StaticResource LaserComboStyle}"
                                  Margin="0,0,16,8" />
                        <TextBlock Grid.Row="1" Grid.Column="6" Text="最大功率(W)" Style="{StaticResource LaserLabelStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="7"
                                 Text="{Binding CurrentHwdWaveSettings.MaximumPower}"
                                 Style="{StaticResource LaserInputStyle}"
                                 Margin="0,0,0,8" />

                        <Grid Grid.Row="2"
                              Grid.Column="0"
                              Grid.ColumnSpan="8"
                              Visibility="{Binding IsHwdSegmentMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="82" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="脉冲间隔(ms)" Style="{StaticResource LaserLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding CurrentHwdWaveSettings.PulseInterval}"
                                     Style="{StaticResource LaserInputStyle}"
                                     Margin="0,0,16,0" />
                            <TextBlock Grid.Column="2" Text="调制周期(ms)" Style="{StaticResource LaserLabelStyle}" />
                            <TextBox Grid.Column="3"
                                     Text="{Binding CurrentHwdWaveSettings.ModulationPeriod}"
                                     Style="{StaticResource LaserInputStyle}"
                                     Margin="0,0,16,0" />
                            <TextBlock Grid.Column="4" Text="出光比例(%)" Style="{StaticResource LaserLabelStyle}" />
                            <TextBox Grid.Column="5"
                                     Text="{Binding CurrentHwdWaveSettings.OutputRatio}"
                                     Style="{StaticResource LaserInputStyle}"
                                     Margin="0,0,16,0" />
                            <TextBlock Grid.Column="6" Text="平均功率(W)" Style="{StaticResource LaserLabelStyle}" />
                            <TextBox Grid.Column="7"
                                     Text="{Binding CurrentHwdWaveSettings.AveragePower}"
                                     IsReadOnly="True"
                                     Style="{StaticResource LaserInputStyle}" />
                        </Grid>

                        <Grid Grid.Row="3"
                              Grid.Column="0"
                              Grid.ColumnSpan="8"
                              Visibility="{Binding IsHwdSegmentMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="82" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="单点能量(J)" Style="{StaticResource LaserLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding CurrentHwdWaveSettings.SinglePointEnergy}"
                                     IsReadOnly="True"
                                     Style="{StaticResource LaserInputStyle}"
                                     Margin="0,8,16,0" />
                        </Grid>

                        <Grid Grid.Row="2"
                              Grid.Column="0"
                              Grid.ColumnSpan="8"
                              Visibility="{Binding IsHwdFcwMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="调制周期(ms)" Style="{StaticResource LaserLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding CurrentHwdWaveSettings.ModulationPeriod}"
                                     Style="{StaticResource LaserInputStyle}"
                                     Margin="0,0,16,0" />
                            <TextBlock Grid.Column="2" Text="出光比例(%)" Style="{StaticResource LaserLabelStyle}" />
                            <TextBox Grid.Column="3"
                                     Text="{Binding CurrentHwdWaveSettings.OutputRatio}"
                                     Style="{StaticResource LaserInputStyle}"
                                     Margin="0,0,16,0" />
                            <TextBlock Grid.Column="4" Text="平均功率(W)" Style="{StaticResource LaserLabelStyle}" />
                            <TextBox Grid.Column="5"
                                     Text="{Binding CurrentHwdWaveSettings.AveragePower}"
                                     IsReadOnly="True"
                                     Style="{StaticResource LaserInputStyle}"
                                     Margin="0,0,16,0" />
                            <TextBlock Grid.Column="6" Text="单点能量(J)" Style="{StaticResource LaserLabelStyle}" />
                            <TextBox Grid.Column="7"
                                     Text="{Binding CurrentHwdWaveSettings.SinglePointEnergy}"
                                     IsReadOnly="True"
                                     Style="{StaticResource LaserInputStyle}" />
                        </Grid>

                        <Grid Grid.Row="3"
                              Grid.Column="0"
                              Grid.ColumnSpan="8"
                              Visibility="{Binding IsHwdFcwMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="脉冲间隔(ms)" Style="{StaticResource LaserLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding CurrentHwdWaveSettings.PulseInterval}"
                                     Style="{StaticResource LaserInputStyle}"
                                     Margin="0,8,16,0" />
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Grid.RowSpan="2"  Grid.Column="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="16 段时间 / 功率"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"
                                       Visibility="{Binding ShowWaveSegmentEditor, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding CurrentWaveSegments}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      BorderBrush="{StaticResource PanelBorderBrush}"
                                      BorderThickness="1"
                                      RowHeight="28"
                                      FontSize="13"
                                      Visibility="{Binding ShowWaveSegmentEditor, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="段号" Binding="{Binding Index}" Width="58" IsReadOnly="True" />
                                    <DataGridTextColumn Binding="{Binding Time}" Width="*">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DataContext.WaveSegmentTimeHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            </DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Power}" Width="*">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DataContext.WaveSegmentPowerHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            </DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid Grid.Row="0"
                                  Grid.RowSpan="2"
                                  Visibility="{Binding IsHwdFcwMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="FCW 波形参数"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,18" />
                                <Grid Grid.Row="1" Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="渐进时间(ms)" Style="{StaticResource LaserLabelStyle}" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding CurrentHwdWaveSettings.FcwRampUpTime}"
                                             Style="{StaticResource LaserInputStyle}" />
                                </Grid>
                                <Grid Grid.Row="2" Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="连续功率(%)" Style="{StaticResource LaserLabelStyle}" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding CurrentHwdWaveSettings.FcwContinuousPower}"
                                             Style="{StaticResource LaserInputStyle}" />
                                </Grid>
                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="渐出时间(ms)" Style="{StaticResource LaserLabelStyle}" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding CurrentHwdWaveSettings.FcwRampDownTime}"
                                             Style="{StaticResource LaserInputStyle}" />
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,12,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="参数信息" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />

                            <Grid Grid.Row="1"
                                  VerticalAlignment="Top"
                                  Visibility="{Binding IsHwqSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="激光功率(W):" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayLaserPower}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="波形号:" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayWaveNumber}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="波形模式:" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayWaveMode}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="触发方式:" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayTriggerMode}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="单点能量(J):" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplaySinglePointEnergy}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="出光点数:" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayOutputPointCount}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="平均功率:" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayAveragePower}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="模拟量(v):" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayAnalogVoltage}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1"
                                  VerticalAlignment="Top"
                                  Visibility="{Binding IsHwdSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="实时功率(W):" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayRealtimeLaserPower}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="波形号:" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayWaveNumber}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="出光模式:" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayWaveMode}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="触发模式:" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayTriggerMode}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="最大功率(W):" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayLaserPower}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="脉冲间隔(ms):" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayHwdPulseInterval}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="平均功率(W):" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayAveragePower}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="单点能量(J):" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplaySinglePointEnergy}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="4"
                                        Grid.Column="1"
                                        Style="{StaticResource ParameterSummaryItemStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="出光点数:" Style="{StaticResource ParameterSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding DisplayOutputPointCount}" Style="{StaticResource ParameterSummaryValueStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Grid.Row="1"
                            Style="{StaticResource PanelCardStyle}"
                            Margin="0,0,12,0"
                            Visibility="{Binding IsHwqSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="系统参数" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />

                            <Grid Grid.Row="1" Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="触发方式" Style="{StaticResource LaserLabelStyle}" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding LaserTriggerModes}"
                                          SelectedIndex="{Binding CurrentSystemSettings.LaserTriggerModeIndex}"
                                          Style="{StaticResource LaserComboStyle}" />
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <CheckBox Content="红光外控使能"
                                          IsChecked="{Binding CurrentSystemSettings.RedLightExternalEnabled}"
                                          FontSize="13"
                                          Margin="0,0,0,12" />
                                <CheckBox Content="波形外控使能"
                                          IsChecked="{Binding CurrentSystemSettings.WaveExternalEnabled}"
                                          FontSize="13"
                                          Margin="0,0,0,12" />
                                
                                    <CheckBox Content="外控模拟调制"
                                          IsChecked="{Binding CurrentSystemSettings.AnalogModulationEnabled}"
                                          FontSize="13"
                                          Margin="0,0,0,12" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <CheckBox Content="外控数字调制"
                                          IsChecked="{Binding CurrentSystemSettings.DigitalModulationEnabled}"
                                          FontSize="13"
                                          Margin="0,0,0,12" />
                                    <CheckBox Content="激光触发外控使能"
                                          IsChecked="{Binding CurrentSystemSettings.LaserTriggerExternalEnabled}"
                                          FontSize="13"
                                          Margin="0,0,0,12" />
                                </StackPanel>
                            </Grid>

                            <Button Grid.Row="3"
                                    Content="修改系统参数"
                                    Command="{Binding SaveSystemSettingsCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Width="132" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Grid.Row="1"
                            Style="{StaticResource PanelCardStyle}"
                            Margin="0,0,12,0"
                            Visibility="{Binding IsHwdSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="系统参数" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />

                            <StackPanel Grid.Row="1">
                                <CheckBox Content="波形外控使能"
                                          IsChecked="{Binding CurrentHwdSystemSettings.WaveExternalEnabled}"
                                          FontSize="13"
                                          Margin="0,0,0,12" />
                                <CheckBox Content="激光触发外控使能"
                                          IsChecked="{Binding CurrentHwdSystemSettings.LaserTriggerExternalEnabled}"
                                          FontSize="13"
                                          Margin="0,0,0,12" />
                            </StackPanel>

                            <Button Grid.Row="2"
                                    Content="修改系统参数"
                                    Command="{Binding SaveSystemSettingsCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Width="132" />
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2" Grid.RowSpan="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="250" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource PanelCardStyle}" Padding="14" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock Text="出光控制"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#0F172A" />
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="状态只读，操作作用于当前选中激光器"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            BorderBrush="#BAE6FD"
                                            BorderThickness="1"
                                            Background="#F0F9FF"
                                            Padding="12,10"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="1" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" Margin="0,0,14,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="44" />
                                                    <RowDefinition Height="44" />
                                                    <RowDefinition Height="44" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Text="出光动作" Style="{StaticResource LaserSectionTitleStyle}" />
                                                <Button Content="{Binding ContinuousOutputText}"
                                                        Grid.Row="1"
                                                        Command="{Binding ToggleContinuousOutputCommand}"
                                                        Style="{StaticResource LaserControlButtonStyle}" />
                                                <Button Content="点焊"
                                                        Grid.Row="2"
                                                        Command="{Binding PointWeldCommand}"
                                                        Style="{StaticResource LaserControlButtonStyle}" />
                                                <Button Content="{Binding LaserLockText}"
                                                        Grid.Row="3"
                                                        Command="{Binding ToggleLaserLockCommand}"
                                                        Style="{StaticResource LaserControlButtonStyle}" />
                                            </Grid>

                                            <Border Grid.Column="1"
                                                    Width="1"
                                                    Background="#BAE6FD"
                                                    Margin="0,2" />

                                            <Grid Grid.Column="2" Margin="14,0,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="44" />
                                                    <RowDefinition Height="44" />
                                                    <RowDefinition Height="44" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Text="辅助控制" Style="{StaticResource LaserSectionTitleStyle}" />
                                                <Button Content="{Binding RedLightText}"
                                                        Grid.Row="1"
                                                        Command="{Binding ToggleRedLightCommand}"
                                                        Style="{StaticResource LaserControlButtonStyle}" />
                                                <Button Content="清除出光点数"
                                                        Grid.Row="2"
                                                        Command="{Binding ClearPointCountCommand}"
                                                        Style="{StaticResource LaserControlButtonStyle}" />
                                                <Button Content="清除错误"
                                                        Grid.Row="3"
                                                        Command="{Binding ClearErrorCommand}"
                                                        Style="{StaticResource LaserControlButtonStyle}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource PanelCardStyle}" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="波形预览" FontSize="19" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <lvc:CartesianChart Grid.Row="1"
                                                    Series="{Binding Series}"
                                                    XAxes="{Binding XAxes}"
                                                    YAxes="{Binding YAxes}"
                                                    LegendPosition="Hidden" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
