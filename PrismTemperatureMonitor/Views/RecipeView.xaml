<UserControl x:Class="PrismTemperatureMonitor.Views.RecipeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1440">
    <UserControl.Resources>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ShellBackgroundBrush}" Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelCardStyle}" Padding="18,14" Margin="0,0,0,18">
            <Grid>
                <StackPanel>
                    <TextBlock Text="配方管理" FontSize="26" FontWeight="SemiBold" />
                    <TextBlock Text="16 个配方；编号固定不可修改，配方名称和起始 PLC 地址可通过底部输入框修改"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="13"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="PLC IP"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="0,0,8,0" />
                    <TextBox Width="150"
                             Text="{Binding PlcIpAddress, UpdateSourceTrigger=LostFocus}"
                             Style="{StaticResource InputTextBoxStyle}"
                             Margin="0,0,10,0" />
                    <Border Background="#F8FAFC"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,7"
                            Margin="0,0,10,0">
                        <TextBlock Text="{Binding PlcState}" Foreground="{StaticResource SecondaryTextBrush}" />
                    </Border>
                    <Button Content="连接PLC"
                            Command="{Binding ConnectPlcCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="读取选中配方"
                            Command="{Binding ReadSelectedRecipeCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.02*" MinWidth="410" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.38*" MinWidth="640" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelCardStyle}" Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="配方列表" FontSize="19" FontWeight="SemiBold" />
                            <TextBlock Text="表格只读；选中后在底部修改配方名称和起始地址"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"
                                       Margin="0,3,0,0" />
                        </StackPanel>

                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="#E0F2FE"
                                BorderBrush="#BAE6FD"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,5">
                            <TextBlock Text="{Binding Recipes.Count, StringFormat=共 {0} 个配方}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Recipes}"
                              SelectedItem="{Binding SelectedRecipe}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              RowHeight="38"
                              FontSize="13"
                              Background="#FFFFFF"
                              BorderBrush="#E2E8F0"
                              BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="编号" Binding="{Binding Code}" Width="88" IsReadOnly="True" />
                            <DataGridTextColumn Header="配方名称" Binding="{Binding Name}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="起始地址" Binding="{Binding StartByteOffset, StringFormat=DB15.DBB{0}}" Width="130" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="配方参数设置" FontSize="19" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedRecipe.Description}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"
                                       Margin="0,3,0,0" />
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedRecipe.Name}"
                                       HorizontalAlignment="Right"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedRecipe.StartByteOffset, StringFormat=PLC 起始地址 DB15.DBB{0}}"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedRecipe.ParameterGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FBFDFF"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="14"
                                            Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,10" />

                                            <ItemsControl ItemsSource="{Binding Parameters}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="150" />
                                                                <ColumnDefinition Width="105" />
                                                                <ColumnDefinition Width="60" />
                                                                <ColumnDefinition Width="125" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{Binding Name}"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Value}"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="SemiBold" />
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding Unit}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="10,0,0,0"
                                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                                            <TextBlock Grid.Column="3"
                                                                       Text="{Binding AddressText}"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{StaticResource AccentBrush}" />
                                                            <TextBlock Grid.Column="4"
                                                                       Text="{Binding Remark}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelCardStyle}" Margin="0,18,0,0" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="修改选中配方"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedRecipe.Code}"
                           VerticalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,0,10,0" />

                <TextBox Grid.Column="2"
                         Text="{Binding EditRecipeName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBoxStyle}"
                         Margin="0,0,10,0"
                         ToolTip="配方名称" />

                <TextBox Grid.Column="3"
                         Text="{Binding EditStartByteOffset, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBoxStyle}"
                         Margin="0,0,10,0"
                         ToolTip="起始地址字节偏移，例如 0、324、648" />

                <Button Grid.Column="4"
                        Content="修改"
                        Command="{Binding ApplySelectedRecipeCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinWidth="78"
                        Margin="0,0,8,0" />

                <Button Grid.Column="5"
                        Content="重置"
                        Command="{Binding ResetSelectedRecipeEditCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="78"
                        Margin="0" />

                <TextBlock Grid.Column="6"
                           Text="{Binding OperationMessage}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
