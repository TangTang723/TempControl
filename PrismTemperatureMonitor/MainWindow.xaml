<Window x:Class="PrismTemperatureMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prism="http://prismlibrary.com/"
        mc:Ignorable="d"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="温度监控上位机"
        MinHeight="768"
        MinWidth="1180"
        Height="900"
        Width="1440"
        Background="{StaticResource ShellBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="#FFFFFF"
                BorderBrush="#D8E1EA"
                BorderThickness="0,0,0,1">
            <Grid Height="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="22,0,34,0" VerticalAlignment="Center">
                    <TextBlock Text="温度监控上位机" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="Prism Industrial Monitor" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                </StackPanel>

                <Menu Grid.Column="1"
                      Background="Transparent"
                      Foreground="{StaticResource PrimaryTextBrush}"
                      FontSize="15"
                      FontWeight="SemiBold"
                      VerticalAlignment="Center">
                    <MenuItem Header="温度监控"
                              Command="{Binding NavigateCommand}"
                              CommandParameter="TemperatureMonitor" />
                    <MenuItem Header="配方管理"
                              Command="{Binding NavigateCommand}"
                              CommandParameter="Recipe" />
                    <MenuItem Header="激光器参数"
                              Command="{Binding NavigateCommand}"
                              CommandParameter="LaserParameters" />
                </Menu>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,22,0">
                    <Ellipse Width="9" Height="9" Fill="#22C55E" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding CurrentPageTitle}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" />
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl prism:RegionManager.RegionName="MainContentRegion" />
    </DockPanel>
</Window>
